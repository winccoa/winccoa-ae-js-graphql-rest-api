# GraphQL Server Configuration
# Copy this file to .env and adjust the values

# Server Host
# Set to the interface to listen on. Default: 0.0.0.0 (all interfaces)
# Examples: 0.0.0.0 (all interfaces), localhost, 127.0.0.1, ::1 (IPv6)
GRAPHQL_HOST=0.0.0.0

# Server Port
GRAPHQL_PORT=4000

# Authentication Settings
# Set to true to disable all authentication (not recommended for production)
DISABLE_AUTH=false

# JWT Secret Key (change this in production!)
JWT_SECRET=your-secret-key-change-in-production

# Authentication Mode
# Controls how username/password logins are validated:
#   config  (default) — only env-var credentials (ADMIN_USERNAME / READONLY_USERNAME)
#   winccoa           — only WinCC OA user database (users defined in WinCC OA project)
#   both              — try env-var first, fall back to WinCC OA
AUTH_MODE=config

# Admin User Credentials (used when AUTH_MODE=config or AUTH_MODE=both)
# If set, these credentials can be used to login with full access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Direct Access Token (non-JWT, not affected by AUTH_MODE)
# If set, this token can be used directly in the Authorization header for full access
# Example: Authorization: Bearer your-direct-access-token
DIRECT_ACCESS_TOKEN=

# Read-Only User Credentials (used when AUTH_MODE=config or AUTH_MODE=both)
# If set, these credentials provide read-only access (queries only, no mutations)
READONLY_USERNAME=readonly
READONLY_PASSWORD=readonly123

# Read-Only Direct Access Token (non-JWT, not affected by AUTH_MODE)
# If set, this token provides direct read-only access
# Example: Authorization: Bearer your-readonly-token
READONLY_TOKEN=

# WinCC OA Read-Only Users (used when AUTH_MODE=winccoa or AUTH_MODE=both)
# Comma-separated list of WinCC OA usernames that get 'readonly' role.
# All other WinCC OA users get 'admin' role.
# Example: WINCCOA_READONLY_USERS=guest,viewer
WINCCOA_READONLY_USERS=

# Token Expiry (in milliseconds)
# Default: 3600000 (1 hour)
TOKEN_EXPIRY_MS=3600000

# Logging Level
# Options: debug, info, warn, error
LOG_LEVEL=info

# CORS Configuration
# Set to "*" to allow all origins, or specify specific origins separated by commas
# Example: "http://localhost:3000,https://myapp.com"
CORS_ORIGIN=*

# MCP Server Configuration
# Enable MCP (Model Context Protocol) server for exposing WinCC OA functions
MCP_ENABLED=true

# MCP Server Host
# Set to the interface to listen on. Default: 0.0.0.0 (all interfaces)
MCP_HOST=0.0.0.0

# MCP Server Port (separate from GraphQL port)
MCP_PORT=3001

# MCP Bearer Token (optional)
# If set, clients must provide this token in Authorization header for MCP requests
# Example: Authorization: Bearer your-mcp-token
MCP_BEARER_TOKEN=